{
  "$schema": "https://www.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "env": { "ENABLE_LSP_TOOL": "1" },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_CONFIG_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
